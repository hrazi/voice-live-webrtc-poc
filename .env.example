# Azure Voice Live resource endpoint (Microsoft Foundry resource).
# Example: https://my-foundry-resource.services.ai.azure.com
AZURE_VOICELIVE_ENDPOINT=https://<your-resource>.services.ai.azure.com

# Model deployment to use (WebRTC uses global standard deployments).
AZURE_VOICELIVE_MODEL=gpt-realtime

# API version for the WebRTC /calls endpoint.
AZURE_VOICELIVE_API_VERSION=2026-01-01-preview

# AUTH — choose ONE:
# Option A (recommended): Microsoft Entra. Leave AZURE_VOICELIVE_API_KEY unset
#   and sign in with `az login`. The server uses DefaultAzureCredential and
#   needs the "Cognitive Services User" + "Foundry User" roles on the resource.
#
# Option B: API key. Uncomment and paste a key from the resource.
# AZURE_VOICELIVE_API_KEY=<your-api-key>

# PORT=3000
